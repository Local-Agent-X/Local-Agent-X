# Local Agent X Configuration
# Copy this to .env and fill in your values

# OpenAI API key (optional if using OAuth)
OPENAI_API_KEY=

# Server port
SAX_PORT=7007

# Gateway auth token (auto-generated on first run if empty)
SAX_AUTH_TOKEN=

# Workspace directory (where the agent can read/write files)
SAX_WORKSPACE=./workspace

# ── Service URLs (override if running on non-default ports) ──
# SAX_OLLAMA_URL=http://127.0.0.1:11434
# SAX_SD_SERVER_URL=http://127.0.0.1:7860
# SAX_VIDEO_SERVER_URL=http://127.0.0.1:7861
# SAX_XTTS_SERVER_URL=http://127.0.0.1:7862

# ── Limits & Timeouts ──
# SAX_AGENT_TIMEOUT_MS=300000
# SAX_MAX_UPLOAD_BYTES=104857600
# SAX_RATE_LIMIT_MAX=120
