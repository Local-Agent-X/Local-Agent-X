# Local Agent X Configuration
# Copy this to .env and fill in your values

# OpenAI API key (optional if using OAuth)
OPENAI_API_KEY=

# Server port
LAX_PORT=7007

# Gateway auth token (auto-generated on first run if empty)
LAX_AUTH_TOKEN=

# Workspace directory (where the agent can read/write files)
LAX_WORKSPACE=./workspace

# ── Service URLs (override if running on non-default ports) ──
# LAX_OLLAMA_URL=http://127.0.0.1:11434
# LAX_SD_SERVER_URL=http://127.0.0.1:7860
# LAX_VIDEO_SERVER_URL=http://127.0.0.1:7861
# LAX_XTTS_SERVER_URL=http://127.0.0.1:7862

# ── Limits & Timeouts ──
# LAX_AGENT_TIMEOUT_MS=300000
# LAX_MAX_UPLOAD_BYTES=104857600
# LAX_RATE_LIMIT_MAX=120
