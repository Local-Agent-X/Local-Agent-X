node_modules/
dist/
.env
voice-models/
*.log

# Auth tokens & databases
.lax/
.sax/  # legacy path, pre-rename; keep blocked so any stale dir on disk isn't accidentally staged
*.db
*.db-shm
*.db-wal

# OS
.DS_Store
Thumbs.db

# Claude Code local config — ignore local state, keep shared skills
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/

# Workspace — personal files, agent-built apps, generated content
# These sync via the brain/memory repo, not the code repo
workspace/*
!workspace/.gitkeep
index.html
desktop/release/

# Protocol importer cache (npx scripts/import-protocols.mjs)
.protocol-import-cache/

# Auto-generated on every server start by src/manifest-generator.ts
config/app-manifest.json

# Scratch files agents/workers write while iterating. Autopilot's overnight
# run on 2026-04-30 leaked .tmp-build*.txt / .tmp-classifier*.json /
# .tmp-test*.txt into commits — block the pattern so it can't recur.
.tmp-*
probe*.mjs
junit.xml

# Vitest coverage output (npm run test:coverage)
coverage/

# Stray "{}" artifact — 0-byte file that intermittently appears in repo root
# during commits/test runs. Source unidentified after ~30 min of probing
# (precommit hook, full vitest, individual tests in isolation, empty commits
# all failed to reliably reproduce). Harmless but noisy in `git status`.
{}

# Python bytecode cache — regenerated on every import, version-tied,
# never useful in the repo. Universal Python convention.
__pycache__/
*.pyc

# Local research / scratch notes kept next to the repo. Not committed
# because they tend to accumulate personal/business content (supplement-
# brand comparisons, etc.) that shouldn't ride along on a public push.
/research/

# Avalonia installer build outputs (regenerated by `dotnet build` /
# `dotnet publish` / scripts/build-mac-installer.sh). CI rebuilds these
# on every release tag and uploads them as GitHub Release assets — they
# should never be committed.
installer/bin/
installer/obj/
installer/dist-mac/

# Native speech helper build outputs (swiftc + csc produce these from
# sources in desktop/native/{mac,win}/ via `npm run build:native`). CI
# rebuilds them as part of `npm run dist`; sources are committed, binaries
# are not — Mach-Os and PE binaries don't belong in git.
# Also covers the bundled Whisper tiny.en blob (~104MB ONNX) which
# build:native:whisper fetches from huggingface — never committed.
desktop/native/dist-bin/

# Vitest JSON reporter dumps (one-off scan output, can be 500KB+).
# Regenerated whenever someone runs `vitest --reporter=json > vt-results.json`.
vt-results.json

# Local scratch backup dirs created during refactors. Prefixed `temp-`
# so the convention is clear: temporary, not for history.
temp-*/

# Local dev/testing convention notes — kept out of history
TESTING.md

# Red-team / security audit reports. These map every defense by file:line,
# state the conceded architectural limits, and can carry live unpatched
# findings with repro steps — a playbook for an attacker. This is a PUBLIC
# repo; these stay local-only. Block the whole class so a future round's
# report can't be `git add .`'d in by accident.
ari-redteam-*.md
*-redteam-*.md
*-security-report.md
*-threat-report.md
