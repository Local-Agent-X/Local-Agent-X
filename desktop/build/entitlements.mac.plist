<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- JIT + unsigned executable memory: V8 (Node + Electron) needs both
       to JIT-compile JavaScript. Without these, hardened runtime kills
       the process the moment V8 maps a code page as W+X. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- dyld env vars: Electron's helper processes use DYLD_*_PATH at
       launch. Hardened runtime ignores these by default. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>

  <!-- Microphone + camera entitlements pair with NSMicrophoneUsageDescription
       / NSCameraUsageDescription in Info.plist. Voice mode (mic) and the
       camera_capture tool (camera) both depend on these. -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
  <key>com.apple.security.device.camera</key>
  <true/>

  <!-- SFSpeechRecognizer access (replaces the Browser-tier webkitSR path
       under Electron's keyless Chromium). Pairs with the matching
       NSSpeechRecognitionUsageDescription in the .app's Info.plist and
       in the bundled LaxSpeech.app helper. Without it, the helper's
       requestAuthorization call comes back .denied under hardened runtime. -->
  <key>com.apple.developer.speech-recognition</key>
  <true/>

  <!-- Network access: LAX speaks to provider APIs (outbound, "client")
       and binds the local server on 127.0.0.1 for the renderer to hit
       ("server"). -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>
</dict>
</plist>
