{
  "name": "local-agent-x-desktop",
  "version": "0.5.0",
  "description": "Local Agent X — Desktop Companion",
  "main": "dist/loader.js",
  "scripts": {
    "build:native:mac": "bash native/mac/build.sh",
    "build:native:win": "powershell -ExecutionPolicy Bypass -File native/win/build.ps1",
    "build:native:whisper": "node native/whisper/fetch.mjs",
    "build:native": "node -e \"const p=process.platform;const cp=require('child_process');cp.execSync(p==='darwin'?'npm run build:native:mac':p==='win32'?'npm run build:native:win':'echo [native-speech] no helper for '+p,{stdio:'inherit'});cp.execSync('npm run build:native:whisper',{stdio:'inherit'})\"",
    "build": "tsc && npm run build:native",
    "start": "electron dist/main.js",
    "dev": "npm run build && electron dist/main.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.0"
  },
  "build": {
    "appId": "com.openagentx.desktop",
    "productName": "Local Agent X",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../public/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "../public/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../public/icon.ico",
      "sign": false,
      "extraResources": [
        {
          "from": "native/dist-bin/lax-speech-win.exe",
          "to": "lax-speech-win.exe"
        },
        {
          "from": "native/dist-bin/whisper-tiny-en",
          "to": "whisper-tiny-en",
          "filter": ["**/*"]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "../public/icon.png",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "extraResources": [
        {
          "from": "native/dist-bin/LaxSpeech.app",
          "to": "LaxSpeech.app",
          "filter": ["**/*"]
        },
        {
          "from": "native/dist-bin/whisper-tiny-en",
          "to": "whisper-tiny-en",
          "filter": ["**/*"]
        }
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Local Agent X uses the microphone for voice mode and speech-to-text.",
        "NSCameraUsageDescription": "Local Agent X uses the camera for the camera_capture tool when you request it.",
        "NSSpeechRecognitionUsageDescription": "Local Agent X uses on-device speech recognition to turn your voice into text.",
        "NSAppleEventsUsageDescription": "Local Agent X may control other apps when you ask it to.",
        "LSMinimumSystemVersion": "11.0"
      }
    },
    "dmg": {
      "writeUpdateInfo": false
    }
  }
}
