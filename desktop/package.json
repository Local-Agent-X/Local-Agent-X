{
  "name": "local-agent-x-desktop",
  "version": "0.1.0",
  "description": "Local Agent X — Desktop Companion",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "electron dist/main.js",
    "dev": "tsc && electron dist/main.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.0"
  },
  "build": {
    "appId": "com.openagentx.desktop",
    "productName": "Local Agent X",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../public/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "../public/favicon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../public/icon.ico",
      "sign": false
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "../public/favicon.png",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Local Agent X uses the microphone for voice mode and speech-to-text.",
        "NSCameraUsageDescription": "Local Agent X uses the camera for the camera_capture tool when you request it.",
        "NSAppleEventsUsageDescription": "Local Agent X may control other apps when you ask it to.",
        "LSMinimumSystemVersion": "11.0"
      }
    },
    "dmg": {
      "writeUpdateInfo": false
    }
  }
}
