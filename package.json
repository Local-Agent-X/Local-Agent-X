{
  "name": "open-agent-x",
  "version": "0.1.0",
  "description": "Personal AI agent with voice conversation, runtime security, and free OpenAI subscription access",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --max-old-space-size=512 --import=tsx --watch src/index.ts",
    "start": "node --max-old-space-size=512 dist/index.js",
    "build:ari": "node scripts/build-ari.js",
    "build": "npm run build:ari && tsc",
    "postinstall": "npm run build:ari",
    "test": "tsx src/test-suite.ts",
    "setup-ai": "node scripts/setup-ai.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@arikernel/adapters": "file:packages/arikernel/adapters",
    "@arikernel/audit-log": "file:packages/arikernel/audit-log",
    "@arikernel/cli": "^0.1.3",
    "@arikernel/control-plane": "file:packages/arikernel/control-plane",
    "@arikernel/core": "file:packages/arikernel/core",
    "@arikernel/policy-engine": "file:packages/arikernel/policy-engine",
    "@arikernel/runtime": "file:packages/arikernel/runtime",
    "@arikernel/sidecar": "file:packages/arikernel/sidecar",
    "@arikernel/taint-tracker": "file:packages/arikernel/taint-tracker",
    "@arikernel/tool-executors": "file:packages/arikernel/tool-executors",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.8.0",
    "clipboardy": "^5.3.1",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "fast-glob": "^3.3.3",
    "imapflow": "^1.2.18",
    "mammoth": "^1.12.0",
    "nodemailer": "^8.0.4",
    "openai": "^4.86.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "playwright": "^1.58.2",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/ws": "^8.5.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
