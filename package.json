    "test": "tsx src/test-suite.ts",
    "setup-ai": "node scripts/setup-ai.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@arikernel/adapters": "file:packages/arikernel/adapters",
