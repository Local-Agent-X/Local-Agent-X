{
	"name": "@arikernel/sidecar",
	"private": true,
	"version": "0.1.2",
	"description": "Sidecar proxy enforcement mode for AriKernel — stateless HTTP execution proxy",
	"license": "SEE LICENSE IN LICENSE.md",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/AriKernel/arikernel.git",
		"directory": "packages/sidecar"
	},
	"homepage": "https://github.com/AriKernel/arikernel#readme",
	"bugs": {
		"url": "https://github.com/AriKernel/arikernel/issues"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc --noEmit",
		"clean": "rimraf dist"
	},
	"dependencies": {
		"@arikernel/core": "file:../core",
		"@arikernel/control-plane": "file:../control-plane",
		"@arikernel/runtime": "file:../runtime",
		"@arikernel/tool-executors": "file:../tool-executors",
		"@arikernel/policy-engine": "file:../policy-engine"
	},
	"devDependencies": {
		"typescript": "^5.7.2",
		"vitest": "^2.1.8"
	}
}
